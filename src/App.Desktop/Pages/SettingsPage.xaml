<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="App_Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:App_Desktop.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="28" Spacing="18">
            <StackPanel Spacing="6">
                <TextBlock Text="Settings" Style="{StaticResource SectionTitleTextBlockStyle}" />
                <TextBlock Text="Tune performance, privacy, model access, and diagnostics." Style="{StaticResource MutedTextBlockStyle}" />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Appearance and Performance" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ThemeComboBox" Header="Theme" />
                        <ComboBox x:Name="PerformanceComboBox" Grid.Column="1" Header="Performance mode" />
                    </Grid>
                    <Button Content="Save preferences" Click="SavePreferences_Click" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Hugging Face Access" FontWeight="SemiBold" />
                    <TextBlock Text="A token is only used for gated model downloads or optional diarization models." Style="{StaticResource MutedTextBlockStyle}" />
                    <PasswordBox x:Name="TokenPasswordBox" Header="Access token" PlaceholderText="hf_..." MaxWidth="520" HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Save token" Click="SaveToken_Click" />
                        <Button Content="Clear token" Click="ClearToken_Click" />
                    </StackPanel>
                    <TextBlock x:Name="TokenStatusTextBlock" Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hardware" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Detect again" Click="DetectHardware_Click" />
                    </Grid>
                    <StackPanel x:Name="DevicesStackPanel" Spacing="8" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Privacy" FontWeight="SemiBold" />
                    <TextBlock Text="Your audio stays on this device. The app does not upload audio or transcripts. Network access is used for Hugging Face model downloads only." Style="{StaticResource MutedTextBlockStyle}" />
                    <TextBlock x:Name="DataPathTextBlock" Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Diagnostics" FontWeight="SemiBold" />
                    <TextBlock Text="Logs are local and useful when a model, codec, or worker dependency fails." Style="{StaticResource MutedTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Copy diagnostic info" Click="CopyDiagnostics_Click" />
                        <Button Content="Open logs folder" Click="OpenLogs_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
