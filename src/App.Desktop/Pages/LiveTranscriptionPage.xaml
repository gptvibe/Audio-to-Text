<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="App_Desktop.Pages.LiveTranscriptionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer>
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="18">
                    <TextBlock Text="Live Transcription" Style="{StaticResource SectionTitleTextBlockStyle}" />

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Microphone" FontWeight="SemiBold" />
                            <ComboBox x:Name="MicrophoneComboBox" Header="Input device" DisplayMemberPath="Name" />
                            <Button x:Name="RefreshMicrophonesButton" Content="Refresh devices" Click="RefreshMicrophones_Click" />
                            <TextBlock x:Name="MicrophoneStatusTextBlock" Text="Choose a microphone before starting." Style="{StaticResource MutedTextBlockStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Model and Device" FontWeight="SemiBold" />
                            <ComboBox x:Name="ModelComboBox" Header="Selected model" DisplayMemberPath="DisplayName" SelectionChanged="ModelComboBox_SelectionChanged" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ModelStatusTextBlock" Text="Checking model..." Style="{StaticResource MutedTextBlockStyle}" VerticalAlignment="Center" />
                                <Button x:Name="DownloadModelButton" Grid.Column="1" Content="Download" Click="DownloadSelectedModel_Click" />
                            </Grid>
                            <ComboBox x:Name="PerformanceComboBox" Header="Performance mode" />
                            <TextBlock x:Name="DeviceBackendTextBlock" Text="Backend will appear after the live worker starts." Style="{StaticResource MutedTextBlockStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Language" FontWeight="SemiBold" />
                            <ComboBox x:Name="LanguageComboBox" Header="Spoken language" SelectedIndex="0">
                                <ComboBoxItem Content="Auto detect" Tag="" />
                                <ComboBoxItem Content="English" Tag="en" />
                                <ComboBoxItem Content="Spanish" Tag="es" />
                                <ComboBoxItem Content="French" Tag="fr" />
                                <ComboBoxItem Content="German" Tag="de" />
                                <ComboBoxItem Content="Japanese" Tag="ja" />
                                <ComboBoxItem Content="Korean" Tag="ko" />
                                <ComboBoxItem Content="Chinese" Tag="zh" />
                            </ComboBox>
                            <CheckBox x:Name="TranslateCheckBox" Content="Translate to English" />
                            <CheckBox x:Name="DetectSpeakersAfterStopCheckBox" Content="Detect speakers after recording stops" IsEnabled="False" />
                            <TextBlock Text="Live mode is local-only. Accuracy and latency depend on model size and CPU/GPU speed; small, base, or tiny faster-whisper models are recommended." Style="{StaticResource MutedTextBlockStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="OutputModeComboBox" Header="Transcript format" SelectionChanged="OutputModeComboBox_SelectionChanged" />
                            <TextBlock x:Name="LiveStateTextBlock" Grid.Column="1" Text="Idle" FontWeight="SemiBold" VerticalAlignment="Bottom" />
                            <Button x:Name="StartLiveButton" Grid.Column="2" Content="Start" Click="StartLive_Click" VerticalAlignment="Bottom" />
                            <Button x:Name="PauseResumeButton" Grid.Column="3" Content="Pause" Click="PauseResume_Click" VerticalAlignment="Bottom" IsEnabled="False" />
                            <Button x:Name="StopLiveButton" Grid.Column="4" Content="Stop" Click="StopLive_Click" VerticalAlignment="Bottom" IsEnabled="False" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Transcript" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button x:Name="CopyLiveButton" Grid.Column="1" Content="Copy" Click="CopyLive_Click" />
                                <Button x:Name="ClearLiveButton" Grid.Column="2" Content="Clear" Click="ClearLive_Click" />
                                <Button x:Name="ExportLiveButton" Grid.Column="3" Content="Export .txt" Click="ExportLive_Click" />
                            </Grid>

                            <TextBox
                                x:Name="LiveTranscriptTextBox"
                                Grid.Row="1"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                PlaceholderText="Live transcript will appear here."
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                IsSpellCheckEnabled="True" />

                            <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Current line" FontWeight="SemiBold" />
                                    <TextBlock x:Name="PartialTextBlock" Text="Waiting for speech." Style="{StaticResource MutedTextBlockStyle}" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="3" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LiveMessageTextBlock" Text="Ready" Style="{StaticResource MutedTextBlockStyle}" VerticalAlignment="Center" />
                                <TextBlock x:Name="ElapsedTextBlock" Grid.Column="1" Text="Elapsed 00:00" VerticalAlignment="Center" />
                                <TextBlock x:Name="LatencyTextBlock" Grid.Column="2" Text="Latency --" Style="{StaticResource MutedTextBlockStyle}" VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="16">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CurrentModelTextBlock" Text="Model: not selected" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="No cloud transcription is used. Live mode keeps a short rolling audio buffer on this device and deletes temporary chunk files after the worker finishes them." Style="{StaticResource MutedTextBlockStyle}" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Page>
