<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="App_Desktop.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:App_Desktop.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer>
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="18">
                    <TextBlock Text="New Transcription" Style="{StaticResource SectionTitleTextBlockStyle}" />

                    <Border
                        x:Name="DropZone"
                        AllowDrop="True"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop"
                        MinHeight="210"
                        Style="{StaticResource CardBorderStyle}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                            <FontIcon Glyph="&#xE898;" FontSize="34" />
                            <TextBlock Text="Drop audio or video here" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text=".mp3, .wav, .m4a, .mp4, .mov, .webm, .aac, .flac" Style="{StaticResource MutedTextBlockStyle}" HorizontalAlignment="Center" />
                            <Button Content="Browse file" Click="BrowseFile_Click" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Source" FontWeight="SemiBold" />
                            <TextBox x:Name="SelectedFileTextBox" PlaceholderText="No file selected" IsReadOnly="True" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="LanguageComboBox" Header="Language" SelectedIndex="0">
                                    <ComboBoxItem Content="Auto detect" Tag="" />
                                    <ComboBoxItem Content="English" Tag="en" />
                                    <ComboBoxItem Content="Spanish" Tag="es" />
                                    <ComboBoxItem Content="French" Tag="fr" />
                                    <ComboBoxItem Content="German" Tag="de" />
                                    <ComboBoxItem Content="Japanese" Tag="ja" />
                                    <ComboBoxItem Content="Korean" Tag="ko" />
                                    <ComboBoxItem Content="Chinese" Tag="zh" />
                                </ComboBox>
                                <CheckBox x:Name="TranslateCheckBox" Grid.Column="1" Content="Translate to English" VerticalAlignment="Bottom" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Model and Device" FontWeight="SemiBold" />
                            <ComboBox x:Name="ModelComboBox" Header="Selected model" DisplayMemberPath="DisplayName" SelectionChanged="ModelComboBox_SelectionChanged" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ModelStatusTextBlock" Text="Checking model..." Style="{StaticResource MutedTextBlockStyle}" VerticalAlignment="Center" />
                                <Button x:Name="DownloadModelButton" Grid.Column="1" Content="Download" Click="DownloadSelectedModel_Click" />
                            </Grid>
                            <ComboBox x:Name="PerformanceComboBox" Header="Performance mode" />
                            <TextBlock x:Name="DeviceSummaryTextBlock" Text="Detecting devices..." Style="{StaticResource MutedTextBlockStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Speaker Detection" FontWeight="SemiBold" />
                            <CheckBox x:Name="DiarizationCheckBox" Content="Enable speaker labels" />
                            <ComboBox x:Name="SpeakerCountComboBox" Header="Expected speakers" SelectedIndex="0">
                                <ComboBoxItem Content="Auto" Tag="" />
                                <ComboBoxItem Content="1" Tag="1" />
                                <ComboBoxItem Content="2" Tag="2" />
                                <ComboBoxItem Content="3" Tag="3" />
                                <ComboBoxItem Content="4" Tag="4" />
                            </ComboBox>
                            <CheckBox x:Name="MergeShortTurnsCheckBox" Content="Merge short speaker turns" IsChecked="True" />
                            <NumberBox x:Name="MinimumSegmentLengthNumberBox" Header="Minimum segment length" Value="1.25" Minimum="0.25" Maximum="10" SmallChange="0.25" />
                            <TextBlock Text="Diarization is optional and may require gated Hugging Face access." Style="{StaticResource MutedTextBlockStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="OutputModeComboBox" Header="Transcript format" SelectionChanged="OutputModeComboBox_SelectionChanged" />
                            <Button x:Name="StartButton" Grid.Column="1" Content="Transcribe" Click="StartTranscription_Click" VerticalAlignment="Bottom" IsEnabled="False" />
                            <Button x:Name="CancelButton" Grid.Column="2" Content="Cancel" Click="CancelTranscription_Click" VerticalAlignment="Bottom" IsEnabled="False" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Transcript" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBox x:Name="SearchTextBox" Grid.Column="1" PlaceholderText="Search transcript" />
                                <Button Grid.Column="2" Content="Find" Click="SearchTranscript_Click" />
                            </Grid>

                            <TextBox
                                x:Name="TranscriptTextBox"
                                Grid.Row="1"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                PlaceholderText="Your transcript will appear here."
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                IsSpellCheckEnabled="True" />

                            <Grid Grid.Row="2" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="SpeakerNamesPanel" Orientation="Horizontal" Spacing="8" />
                                <Button Grid.Column="1" Content="Copy" Click="CopyTranscript_Click" />
                                <Button Grid.Column="2" Content="Clear" Click="ClearTranscript_Click" />
                                <Button Grid.Column="3" Content="Re-run" Click="Rerun_Click" />
                                <Button Grid.Column="4" Content="Export .txt" Click="ExportTxt_Click" />
                                <Button x:Name="DeleteHistoryButton" Grid.Column="5" Content="Delete" Click="DeleteHistory_Click" IsEnabled="False" Visibility="Collapsed" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="16">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CurrentTaskTextBlock" Text="Ready" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ProgressBar x:Name="TaskProgressBar" Grid.Column="1" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" />
                <TextBlock x:Name="PrivacyTextBlock" Grid.Column="2" Text="Your audio stays on this device." Style="{StaticResource MutedTextBlockStyle}" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Page>
